{
  "version": 2,
  "functions": {
    "api/booking-pdf.js": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "node_modules/@sparticuz/chromium/**"
    },
    "api/booking-email.js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
